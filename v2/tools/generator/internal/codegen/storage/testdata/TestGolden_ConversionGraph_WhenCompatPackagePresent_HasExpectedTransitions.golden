# Render with Graphviz using dot
# or try https://dreampuf.github.io/GraphvizOnline/
graph G {
    rankdir=LR;

    subgraph apiversions {
        rank=same;
        node [shape=ellipse, style=dashed, penwidth=1, rankType=min, group=storage];
        "person_v20200101";
        "person_v20220101";
    }

    subgraph storageversions {
        rank=same;
        node [shape=ellipse, style=dashed, penwidth=1, rankType=min, group=storage];
        "person_v20200101s";
        "person_v20200101sc";
        "person_v20220101s";
    }

    edge [arrowhead=vee, arrowtail=vee, dir=forward];
    person_v20200101 -- person_v20200101s
    person_v20200101s -- person_v20200101sc
    person_v20200101sc -- person_v20220101s
    person_v20220101 -- person_v20220101s
}
